# ============================================================
# .env.development.example
# ============================================================
# This is an example of your development environment configuration.
# Copy this to .env.development and modify it for your local machine.

# DATABASE
# Local PostgreSQL connection string (default credentials for local dev)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/broom_kit_dev"

# AUTH.JS
# Local callback URL
NEXTAUTH_URL="http://localhost:3000"
# Run `openssl rand -base64 32` for a new secret
NEXTAUTH_SECRET="dev-secret-key-1234567890-not-secure!"

# REDIS (Local caching/rate limiting)
# Typically running via local docker instance
REDIS_URL="redis://localhost:6379"

# EMAIL (Local SMTP trapping / Resend)
# E.g. Using Mailhog locally
USE_MAILHOG="true"
MAILHOG_HOST="localhost"
MAILHOG_PORT="1025"
FROM_EMAIL="noreply@brumkit.localhost"

# CRON JOBS
CRON_SECRET="dev-my-local-cron-secret"

# ENVIRONMENT
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

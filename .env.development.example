# ============================================================
# .env.development.example
# ============================================================
# Template for local development. Copy to .env.development

# ─── APPLICATION ───────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ─── DATABASE (PostgreSQL) ─────────────────────────────────
# App Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/broom_kit"

# Docker Postgres Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=broom_kit
POSTGRES_PORT=5433

# ─── AUTH.JS ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# ─── REDIS (Caching/Rate Limiting) ──────────────────────────
# App Connection
REDIS_URL="redis://:redis_secret@localhost:6379"

# Docker Redis Config
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# ─── EMAIL (Mailhog) ───────────────────────────────────────
# App Config
USE_MAILHOG="true"
MAILHOG_HOST="localhost"
MAILHOG_PORT="1025"
FROM_EMAIL="noreply@brumkit.local"

# Docker Mailhog Config
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ─── OTHER ─────────────────────────────────────────────────
CRON_SECRET="replace-me-with-openssl-rand-base64-32"
ADMIN_EMAIL="admin@brumkit.local"
RESEND_API_KEY=""

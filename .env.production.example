# ============================================================
# .env.production.example
# ============================================================
# This is an example of your production environment configuration.
# Copy this to .env.production and securely provide actual values.

# DATABASE
# Production database connection string (Neon, Supabase, RDS, etc.)
DATABASE_URL="postgresql://user:secure_password@db.example.com:5432/broom_kit_prod?sslmode=require"

# AUTH.JS
# Your production application URL
NEXTAUTH_URL="https://brumkit.com"
# Must be strongly generated: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-production-secret-key-replace-me-123456"

# REDIS (Production rate limiting / caching)
# e.g., Upstash Redis REST credentials
UPSTASH_REDIS_REST_URL="https://your-database-id.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_xxxxxxxx"
# Optional fallback raw URL connection
REDIS_URL="rediss://default:password@your-database-id.upstash.io:32483"

# EMAIL (Production email sender e.g. Resend)
USE_MAILHOG="false"
RESEND_API_KEY="re_123456789_xxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@brumkit.com"
ADMIN_EMAIL="admin@brumkit.com"

# CRON JOBS
# Must be strongly generated: `openssl rand -base64 32`
CRON_SECRET="your-production-cron-secret"

# ENVIRONMENT
NODE_ENV="production"
NEXT_PUBLIC_API_URL="https://brumkit.com/api"

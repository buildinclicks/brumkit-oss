# ─── Version Control ──────────────────────────────────────────────────────────
.git
.gitignore
.github

# ─── Local secrets (never bake into image) ────────────────────────────────────
.env
.env.*
!.env.production.example
!.env.development.example

# ─── Build artifacts (rebuilt inside Docker) ──────────────────────────────────
**/node_modules
**/.next
**/dist
**/build
**/.turbo

# ─── Dev tooling ──────────────────────────────────────────────────────────────
**/*.log
*.log
.cursor
.vscode
.idea

# ─── Test / coverage ──────────────────────────────────────────────────────────
**/coverage
**/*.lcov
**/test_output.log
**/test_failure.log

# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Docker itself ────────────────────────────────────────────────────────────
docker-compose.override.yml
Dockerfile*
docker/docker-compose.yml
docker/.env*
docker/README.md
docker/.gitkeep.md
